# ralph-config.yaml — Configuration for Ralph autonomous agent
# Copy this file to your project root as ralph-config.yaml and customise.

# ── Project settings ─────────────────────────────────────────
project:
  name: my-app
  repo: "."
  description: "My application"
  build_command: "npm run build"
  test_command: "npm test"
  lint_command: "npm run lint"

# ── Research / competitive analysis ──────────────────────────
research:
  competitors:
    - name: competitor-one
      github: "https://github.com/org/competitor-one"
      website: "https://competitor-one.dev"
    - name: competitor-two
      github: "https://github.com/org/competitor-two"
      website: "https://competitor-two.dev"
  dimensions:
    - performance
    - developer-experience
    - documentation
  auto_discover: true

# ── Schedule ─────────────────────────────────────────────────
schedule:
  interval: "30m"
  max_stories_per_cycle: 3

# ── Development ──────────────────────────────────────────────
development:
  tool: claude          # claude | amp
  max_iterations: 10
  tdd: true
  worktree: false

# ── Release automation ───────────────────────────────────────
release:
  auto_pr: true
  auto_merge: false
  auto_tag: false
  auto_release: false
